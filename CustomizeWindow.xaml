<Window x:Class="BypassCheckerWPF.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalizar Características de Seguridad"
        Height="650" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">
    
    <Window.Resources>
        <SolidColorBrush x:Key="TextColor" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="TextMutedColor" Color="#A1A1AA"/>
        
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#3D3D4D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A5A6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="FeatureRow" TargetType="Border">
            <Setter Property="Background" Value="#2D2D3D"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="⚙️ Personalizar características de seguridad"
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="White"
                   Margin="0,0,0,15"
                   TextAlignment="Center"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="stackFeatures">
                <!-- Cada característica se agregará dinámicamente desde el código -->
            </StackPanel>
        </ScrollViewer>
        
        <!-- Botones de reinicio y cierre -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnRebootNormal" Content="🔄 Reinicio normal" Click="btnRebootNormal_Click" Width="120" Margin="0,0,10,0"/>
            <Button x:Name="btnRebootAdvanced" Content="🔁 Reinicio avanzado (F7)" Click="btnRebootAdvanced_Click" Width="160" Margin="0,0,10,0"/>
            <Button x:Name="btnClose" Content="Cerrar" Click="btnClose_Click" Width="100"/>
        </StackPanel>
    </Grid>
</Window>