
<Window x:Class="BypassCheckerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HyperVision Checker - Análisis de Seguridad" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#7C3AED"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#2D2D3D"/>
        <SolidColorBrush x:Key="TextColor" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="TextMutedColor" Color="#A1A1AA"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header con gradiente -->
        <Border Grid.Row="0" CornerRadius="10" Margin="0,0,0,15" Padding="20">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="🔒 HyperVision Checker" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           TextAlignment="Center"/>
                <TextBlock Text="Análisis de compatibilidad para HyperVision Denuvo" 
                           FontSize="14" 
                           Foreground="#E4E4E7"
                           TextAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Panel de estadísticas -->
        <Border Grid.Row="1" 
                Background="#2D2D3D" 
                CornerRadius="10" 
                Margin="0,0,0,15" 
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#3D3D4D" CornerRadius="8" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🖥️ Virtualización" FontSize="12" Foreground="#A1A1AA"/>
                        <TextBlock x:Name="lblVirtStatus" Text="No verificado" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#3D3D4D" CornerRadius="8" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🔐 VBS/HVCI" FontSize="12" Foreground="#A1A1AA"/>
                        <TextBlock x:Name="lblVbsStatus" Text="No verificado" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="#3D3D4D" CornerRadius="8" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="✅ Compatibilidad" FontSize="12" Foreground="#A1A1AA"/>
                        <TextBlock x:Name="lblCompatStatus" Text="No verificado" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Botones -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,15">
            <Button x:Name="btnCheck" 
                    Content="🔍 Verificar Sistema" 
                    Style="{StaticResource ModernButton}"
                    Background="#7C3AED"
                    Click="btnCheck_Click"/>
            <Button x:Name="btnBypass" 
                    Content="⚡ Verificar Bypass" 
                    Style="{StaticResource ModernButton}"
                    Background="#8B5CF6"
                    Click="btnBypass_Click"/>
            <Button x:Name="btnClear" 
                    Content="🗑️ Limpiar" 
                    Style="{StaticResource ModernButton}"
                    Background="#EF4444"
                    Click="btnClear_Click"/>
        </StackPanel>
        
        <!-- Área de resultados -->
        <Border Grid.Row="3" 
                Background="#2D2D3D" 
                CornerRadius="10" 
                Margin="0,0,0,10" 
                Padding="10">
            <Border BorderBrush="#3D3D4D" BorderThickness="1" CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtResults" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True"
                             Background="#2D2D3D"
                             Foreground="#E4E4E7"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="10"/>
                </ScrollViewer>
            </Border>
        </Border>
        
        <!-- Barra de estado - CORREGIDA: eliminado CornerRadius -->
        <StatusBar Grid.Row="4" Background="#2D2D3D" BorderBrush="#3D3D4D" BorderThickness="1">
            <StatusBarItem>
                <TextBlock x:Name="lblStatus" 
                           Foreground="#A1A1AA" 
                           Text="✅ Listo para verificar"
                           Margin="10,5"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
